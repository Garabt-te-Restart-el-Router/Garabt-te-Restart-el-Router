<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body {
            background-image: url("/background3.jpg");
            background-repeat: no-repeat;
            background-size: 100%;
        }

        h1 {
            color: white;
            text-align: center;
            -webkit-text-stroke: 1px blue;
            margin-top: 50px;
        }

        .categories-container {
            display: flex;         /* arrange items in a row */
            justify-content: start; /* align items to start */
            gap: 50px;             /* spacing between items */
            margin: 50px auto;     /* center container horizontally */
            padding: 20px;
            flex-wrap: wrap;       /* wrap to next line if screen is small */
            max-width: 1200px;
        }

        .category-item {
            text-align: center;
            color: white;
        }

        .category-item img {
            width: 100px;
            height: 100px;
        }

        .wanttogo {
            position: fixed;
            left: 50px;
            bottom: 50px;
        }

        .card-body {
        background-color: #d3d3d3; /* light grey */
        padding: 15px;
        border-radius: 5px;
        }

        #back-btn {
        position: fixed;
        bottom: 50px;
        left: 50px;
        z-index: 1000;
        padding: 10px 20px;
        font-weight: bold;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
        }

        #back-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 10px rgba(0, 0, 0, 0.3);
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= actualCategoryName %> Destinations</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <h1><%= actualCategoryName %> Destinations</h1>
        <div class="row">
            <% if (destinations.length === 0) { %>
                <p>No destinations found in this category.</p>
            <% } %>
            <% destinations.forEach(dest => { %>
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <!-- Image uses internal name -->
                        <img src="/<%= dest.name %>.png" class="card-img-top" alt="<%= dest.actualName %>">
                        <div class="card-body">
                            <!-- Display actual destination name and country -->
                            <h5 class="card-title"><%= dest.actualName %></h5>
                            <p class="card-text"><%= dest.country %></p>
                            <a href="/destination/<%= dest.name %>" class="btn btn-primary">View</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

<%- include('partials/back-button') %>
</body>
</html>
