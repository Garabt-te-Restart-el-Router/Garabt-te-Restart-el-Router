<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= actualCategoryName %> Destinations</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">

    <style>
        body {
            background-image: url("/background3.jpg");
            background-repeat: no-repeat;
            background-size: cover;
            min-height: 100vh;
        }

        h1 {
            color: white;
            text-align: center;
            -webkit-text-stroke: 1px blue;
            margin: 40px 0;
        }

        /* GRID */
        .destinations-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
            padding-bottom: 60px;
        }

        /* CARD */
        .card {
            height: 100%;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 18px rgba(0,0,0,0.4);
        }

        .card-img-top {
            height: 100%;
            object-fit: cover;
        }

        .card-body {
            background-color: #d3d3d3;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
            border-radius: 0 0 5px 5px;
        }

        /* EMPTY STATE */
        .empty-message {
            text-align: center;
            color: white;
            font-size: 1.4rem;
            margin-top: 80px;
        }
    </style>
</head>

<body>

<%- include('partials/navbar') %>

<div class="container">
    <h1><%= actualCategoryName %> Destinations</h1>

    <% if (!myCollection || myCollection.length === 0) { %>
        <div class="empty-message">
            No destinations found in this category.
        </div>
    <% } else { %>
        <div class="destinations-grid">
            <% myCollection.forEach(dest => { %>
                <div class="card">
                    <img
                        src="/<%= dest.name %>.png"
                        class="card-img-top"
                        alt="<%= dest.actualName %>"
                    >

                    <div class="card-body">
                        <div>
                            <h5 class="card-title"><%= dest.actualName %></h5>
                            <p class="card-text mb-2">
                                <strong><%= dest.country || "Unknown" %></strong>
                            </p>
                        </div>

                        <a
                            href="/destination/<%= dest.name %>"
                            class="btn btn-primary btn-block"
                        >
                            View Destination
                        </a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('partials/back-button') %>

</body>
</html>
