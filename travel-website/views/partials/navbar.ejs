<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <a class="navbar-brand lively" href="/home">
        <img src="/traveltopia.png" alt="Traveltopia Logo" style="height:40px; width:auto; margin-right:10px;">
        Traveltopia
    </a>

    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarContent">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav mr-auto">
            <li class="nav-item">
                <a class="nav-link lively" href="/want-to-go">Want-to-Go</a>
            </li>
        </ul>

        <div class="form-inline my-2 my-lg-0 ml-auto">
            <div class="search-wrapper">
                <form action="/search" method="GET" autocomplete="off" class="d-flex">
                    <input 
                        id="search-input" 
                        class="form-control mr-2" 
                        type="search" 
                        name="q" 
                        placeholder="Search destinations..." 
                        aria-label="Search"
                    >
                    <button class="btn btn-outline-success" type="submit">Search</button>
                </form>

                <div id="search-results" class="list-group search-results-dropdown"></div>
            </div>

            <a href="/logout" class="btn btn-danger ml-2">Logout</a>
        </div>
    </div>
</nav>

<style>
/* --- Lively navbar elements --- */
.lively {
    position: relative;
    transition: transform 0.3s ease, color 0.3s ease;
    font-weight: bold;
    color: #fff;
}

.lively:hover {
    transform: scale(1.1);
    color: #28a745 !important;
}

.lively::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 0;
    height: 2px;
    background-color: #28a745;
    transition: width 0.3s ease;
}

.lively:hover::after {
    width: 100%;
}

/* --- Search wrapper --- */
.search-wrapper {
    position: relative;
    margin-right: 15px;
}

/* Search results dropdown */
.search-results-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 1050;
    display: none;
    max-height: 400px;
    overflow-y: auto;
    box-shadow: 0 4px 6px rgba(0,0,0,0.3);
}

/* Responsive adjustments */
@media (max-width: 991px) {
    .search-wrapper {
        width: 100%;
        margin-right: 0;
        margin-bottom: 10px;
    }
    
    .search-results-dropdown {
        position: static;
        margin-top: 5px;
    }
    
    .btn-danger {
        width: 100%;
        margin-left: 0 !important;
        margin-top: 10px;
    }
}

@media (min-width: 992px) {
    .search-wrapper {
        min-width: 300px;
    }
}
</style>

<script>
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');

    searchInput.addEventListener('input', async (e) => {
        const query = e.target.value.trim();

        if (query.length < 1) {
            searchResults.style.display = 'none';
            searchResults.innerHTML = '';
            return;
        }

        try {
            const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
            const data = await res.json();

            searchResults.innerHTML = '';
            searchResults.style.display = 'block';

            if (data.length > 0) {
                data.forEach(item => {
                    const a = document.createElement('a');
                    a.href = `/destination/${item.name.toLowerCase()}`; 
                    a.classList.add('list-group-item', 'list-group-item-action');
                    a.style.backgroundColor = '#343a40';
                    a.style.color = '#fff';
                    a.style.borderColor = '#454d55';

                    a.innerHTML = `
                        <div style="font-weight: bold;">${item.actualName}</div>
                        <small class="text-muted">
                            ${item.country || 'Unknown'} - ${item.actualCategoryName || 'General'}
                        </small>
                    `;
                    searchResults.appendChild(a);
                });
            } else {
                const div = document.createElement('div');
                div.classList.add('list-group-item');
                div.style.backgroundColor = '#343a40';
                div.style.color = '#dc3545';
                div.style.borderColor = '#454d55';
                div.innerText = 'Destination not Found';
                
                searchResults.appendChild(div);
            }
        } catch (err) {
            console.error(err);
        }
    });

    document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
            searchResults.style.display = 'none';
        }
    });
</script>