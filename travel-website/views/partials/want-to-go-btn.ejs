<div class="wanttogo">
    <form id="wantForm">
        <button type="submit" class="btn btn-secondary">Add to Want-to-Go List</button>
    </form>

    <!-- Feedback message -->
    <div id="feedback-msg"></div>
</div>

<script>
    (function() {
        const form = document.getElementById('wantForm');
        const feedback = document.getElementById('feedback-msg');

        if (!form || !feedback) {
            console.error('Form or feedback element not found');
            return;
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            // Get the destination name from the current URL
            const pathParts = window.location.pathname.split('/');
            const destinationName = pathParts[pathParts.indexOf('destination') + 1];
            const url = `/destination/${destinationName}/add`;

            console.log('Submitting to:', url);

            try {
                const res = await fetch(url, { method: 'POST' });
                const text = await res.text();

                console.log('Server response:', text);

                let msg = 'Added to your Want-to-Go List!';
                let cls = 'success';

                if (text.toLowerCase().includes('already')) {
                    msg = 'Already in your Want-to-Go List!';
                    cls = 'error';
                }

                feedback.innerText = msg;
                feedback.className = `show ${cls}`;

                setTimeout(() => {
                    feedback.className = '';
                    feedback.innerText = '';
                }, 2500);

            } catch (err) {
                console.error('Fetch error:', err);
                feedback.innerText = 'Error adding destination.';
                feedback.className = 'show error';
                setTimeout(() => {
                    feedback.className = '';
                    feedback.innerText = '';
                }, 2500);
            }
        });
    })();
</script>

<style>
    .wanttogo {
        position: relative;
        margin-top: 10px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .btn-secondary {
        font-weight: bold;
    }

    #feedback-msg {
        position: absolute;
        top: 45px; /* below the button */
        left: 50%;
        transform: translateX(-50%);
        padding: 8px 12px;
        border-radius: 5px;
        font-weight: bold;
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        z-index: 100;
        pointer-events: none;
    }

    #feedback-msg.show {
        opacity: 1;
        visibility: visible;
        animation: fadeInOut 2.5s forwards;
    }

    #feedback-msg.success {
        background-color: #28a745;
        color: white;
    }

    #feedback-msg.error {
        background-color: #dc3545;
        color: white;
    }

    @keyframes fadeInOut {
        0% { opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { opacity: 0; }
    }
</style>