<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body {
            background-image: url("/background3.jpg");
            background-repeat: no-repeat;
            background-size: 100%;
        }

        h1 {
            color: white;
            text-align: center;
            -webkit-text-stroke: 1px blue;
            margin-top: 20px;
        }

        /* Image + button container */
        .image-container {
            position: fixed;
            left: 50px;
            top: 150px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        #image {
            width: 193px;
            height: 300px;
        }

        /* Description text */
        .container2 {
            position: fixed;
            left: 300px;
            top: 150px;
            color: white;
            width: 300px;
            text-align: justify;
            text-justify: inter-word;
        }

        /* Video */
        .video {
            position: fixed;
            left: 700px;
            top: 150px;
            width: 300px;
        }
    </style>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= actualName %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1><%= actualName %></h1>
    </div>

    <!-- Image -->
    <div class="image-container">
        <img id="image" src="/<%= name %>.png" alt="<%= actualName %>">
        
        <!-- Include the want-to-go partial -->
        <%- include('partials/want-to-go-btn') %>
    </div>

    <!-- Description -->
    <div class="container2">
        <%= description || 'Annapurna Circuit has been voted as the best long-distance trek in the world, as it combined a wide variety of climate zones from tropics at 600m above sea level to the arctic at 5416m above sea level at the Thorong La pass and cultural variety from Hindu villages at the low foothills to the Tibetan culture of Manang.' %>
    </div>

    <!-- Video -->
    <div class="video">
        <iframe width="500" height="315"
                src="https://www.youtube.com/embed/vG_Ck5bTOnY?si=fXQsJeNNZjZy-bob"
                title="YouTube video player"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen>
        </iframe>
    </div>

    <!-- Back button -->
    <%- include('partials/back-button') %>
</body>
</html>