<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body {
            background-image: url("/background3.jpg");
            background-repeat: no-repeat;
            background-size: 100%;
            /* Removes the white space at the top */
            margin: 0;
            padding: 0;
        }

        h1 {
            color: white;
            text-align: center;
            -webkit-text-stroke: 1px blue;
            margin-top: 50px;
        }

        /* Ensure navbar stays at the very top */
        nav {
            margin-top: 0 !important;
        }

        .card-body {
            background-color: #d3d3d3; /* light grey */
            padding: 15px;
            border-radius: 5px;
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <main class="container">
        <h1>Search Results</h1>

        <% if (locals.notFound || (locals.results && results.length === 0)) { %>
            <div class="no-results" style="text-align: center; color: white; margin-top: 50px;">
                <p>No destinations found matching your search.</p>
                <a href="/home" class="btn btn-secondary">Go back home</a>
            </div>
        <% } else if (locals.results && results.length > 0) { %>
            <div class="row mt-5">
                <% results.forEach(destination => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h3 class="card-title"><%= destination.actualName %></h3>
                                
                                <p class="card-text">
                                    <strong>Country:</strong> <%= destination.country || 'Unknown' %>
                                </p>
                                
                                <p class="card-text">
                                    <strong>Category:</strong> <%= destination.actualCategoryName || 'General' %>
                                </p>
                                
                                <p class="card-text">
                                    <%= destination.description || '' %>
                                </p>
                                
                                <a href="/destination/<%= destination.name.toLowerCase() %>" class="btn btn-primary">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <p style="text-align: center; color: white; margin-top: 20px;">
                Please enter a keyword to search.
            </p>
        <% } %>
    </main>
    <%- include('partials/back-button') %>
</body>
</html>