<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body {
            background-image: url("/background3.jpg");
            background-repeat: no-repeat;
            background-size: cover;
            margin: 0;
            padding: 0;
        }

        h1 {
            color: white;
            text-align: center;
            -webkit-text-stroke: 1px blue;
            margin-top: 50px;
        }

        nav {
            margin-top: 0 !important;
        }

        .scroll-panel {
            overflow-x: auto;
            overflow-y: hidden;
            padding: 15px 0;
        }

        .scroll-row {
            display: flex;
            gap: 20px; /* space between cards */
        }

        .scroll-panel::-webkit-scrollbar {
            height: 8px;
        }

        .scroll-panel::-webkit-scrollbar-thumb {
            background-color: #888;
            border-radius: 4px;
        }

        .scroll-panel::-webkit-scrollbar-thumb:hover {
            background-color: #555;
        }

        .card {
            flex: 0 0 300px; /* fixed width for cards */
            display: flex;
            flex-direction: column;
            height: 100%; 
        }

        .card img {
            height: 400px; /* uniform image height */
            object-fit: cover;
        }

        .card-body {
            background-color: #d3d3d3;
            padding: 15px;
            border-radius: 5px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            flex-grow: 1;
        }

        .card-title {
            font-weight: bold;
            margin-bottom: 10px;
        }

        .btn-primary {
            margin-top: 10px;
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>
<body>
<%- include('partials/navbar') %>

<main class="container">
    <h1>Search Results</h1>

    <% if (locals.notFound || (locals.results && results.length === 0)) { %>
        <div class="no-results" style="text-align: center; color: white; margin-top: 50px;">
            <p>No destinations found matching your search.</p>
            <a href="/home" class="btn btn-secondary">Go back home</a>
        </div>
    <% } else if (locals.results && results.length > 0) { %>
        <div class="scroll-panel mt-4">
            <div class="scroll-row">
                <% results.forEach(destination => { %>
                    <div class="card">
                        <img src="/<%= destination.name.toLowerCase() %>.png"
                             class="card-img-top" alt="<%= destination.actualName %>">
                        <div class="card-body">
                            <div>
                                <h5 class="card-title"><%= destination.actualName %></h5>
                                <p class="card-text"><strong>Country:</strong> <%= destination.country || 'Unknown' %></p>
                                <p class="card-text"><strong>Category:</strong> <%= destination.actualCategoryName || 'General' %></p>
                                <p class="card-text"><%= destination.description || '' %></p>
                            </div>
                            <a href="/destination/<%= destination.name.toLowerCase() %>" class="btn btn-primary">View Details</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } else { %>
        <p style="text-align: center; color: white; margin-top: 20px;">
            Please enter a keyword to search.
        </p>
    <% } %>
</main>

<%- include('partials/back-button') %>
</body>
</html>
