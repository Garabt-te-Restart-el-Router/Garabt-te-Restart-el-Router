<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body {
            background-image: url("/background3.jpg");
            background-repeat: no-repeat;
            background-size: 100%;
        }

        h1 {
            color: white;
            text-align: center;
            -webkit-text-stroke: 1px blue;
            margin-top: 40px;
        }

        .card-body {
            background-color: #e0e0e0;
            text-align: center;
        }

        .pagination-container {
            display: flex;
            justify-content: center;
            margin-top: 30px;
            margin-bottom: 40px;
        }

        /* Empty state styling */
        .empty-state {
            text-align: center;
            margin-top: 120px;
        }

        .empty-state h2 {
            color: #ff4d4d;
            font-size: 2.8rem;
            font-weight: bold;
            opacity: 0;
            animation: fadeIn 1.5s forwards;
        }

        .empty-state p {
            color: white;
            font-size: 1.2rem;
            margin-top: 15px;
            opacity: 0;
            animation: fadeIn 1.5s forwards;
            animation-delay: 0.5s;
        }

        .browse-btn {
            margin-top: 20px;
            font-size: 1.1rem;
            opacity: 0;
            animation: fadeIn 1.5s forwards;
            animation-delay: 1s;
        }

        /* Fade-in animation */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Want-to-Go List</title>

    <link rel="stylesheet"
          href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>

<body>
    <%- include('partials/navbar') %>

    <h1>Your Want-To-Go List</h1>

    <div class="container mt-4">
        <div class="row">

            <% if (!destinations || destinations.length === 0) { %>
                <div class="empty-state col-12">
                    <h2>Your Want-to-Go list is empty</h2>
                    <p>Start exploring destinations and add places you’d love to visit 🌍</p>
                    <button class="btn btn-success browse-btn" onclick="window.location.href='/home'">
                        Browse Destinations
                    </button>
                </div>

            <% } %>

            <% destinations.forEach(dest => { %>
                <div class="col-md-4 mb-4">
                    <div class="card">

                        <img src="/<%= dest.name %>.png"
                             class="card-img-top"
                             alt="<%= dest.actualName %>">

                        <div class="card-body">
                            <h5 class="card-title"><%= dest.actualName %></h5>

                            <p class="card-text">
                                <%= dest.country %> · <%= dest.actualCategoryName %>
                            </p>

                            <div class="d-flex justify-content-center gap-2">
                                <button class="btn btn-primary mr-2"
                                        onclick="window.location.href='/destination/<%= dest.name %>'">
                                    View
                                </button>

                                <form method="POST"
                                    action="/destination/<%= dest.name %>/remove"
                                    style="display:inline;">
                                    <button type="submit" class="btn btn-danger">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>

        </div>

        <!-- PAGINATION -->
        <% if (destinations && destinations.length > 0 && totalPages > 0) { %>
        <div class="pagination-container">

            <% if (currentPage > 1) { %>
                <button class="btn btn-secondary mr-2"
                        onclick="window.location.href='/want-to-go?page=<%= currentPage - 1 %>'">
                    Previous
                </button>
            <% } %>

            <span class="text-white align-self-center">
                Page <%= currentPage %> of <%= totalPages %>
            </span>

            <% if (currentPage < totalPages) { %>
                <button class="btn btn-secondary ml-2"
                        onclick="window.location.href='/want-to-go?page=<%= currentPage + 1 %>'">
                    Next
                </button>
            <% } %>

        </div>
        <% } %>

    </div>
    <%- include('partials/back-button') %>
</body>
</html>
