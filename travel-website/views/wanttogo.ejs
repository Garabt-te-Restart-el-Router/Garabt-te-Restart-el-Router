<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Want-to-Go List</title>
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">

<style>
body {
    background-image: url("/background3.jpg");
    background-repeat: no-repeat;
    background-size: cover;
    margin: 0;
    padding: 0;
}

h1 {
    color: white;
    text-align: center;
    -webkit-text-stroke: 1px blue;
    margin-top: 50px;
}

.scroll-panel {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 15px 0;
}

.scroll-row {
    display: flex;
    gap: 20px;
}

.card {
    flex: 0 0 300px;
    display: flex;
    flex-direction: column;
}

.card img {
    height: 400px;
    object-fit: cover;
}

.card-body {
    background-color: #d3d3d3;
    padding: 15px;
    border-radius: 5px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

/* Toast */
.toast {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: #333;
    color: white;
    padding: 14px 18px;
    border-radius: 8px;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.3s ease;
    z-index: 999;
}
.toast.show {
    opacity: 1;
    transform: translateY(0);
}

/* Empty state animation */
.empty-state {
    text-align: center;
    margin-top: 120px;
}
.empty-state h2 {
    color: #ff4d4d;
    font-size: 2.8rem;
    font-weight: bold;
    opacity: 0;
    animation: fadeIn 1.5s forwards;
}
.empty-state p {
    color: white;
    font-size: 1.2rem;
    margin-top: 15px;
    opacity: 0;
    animation: fadeIn 1.5s forwards;
    animation-delay: 0.5s;
}
.empty-state .browse-btn {
    margin-top: 20px;
    font-size: 1.1rem;
    opacity: 0;
    animation: fadeIn 1.5s forwards;
    animation-delay: 1s;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
</head>

<body>
<%- include('partials/navbar') %>

<main class="container">
    <h1>Your Want-To-Go List</h1>
    <div class="scroll-panel mt-4">
        <div id="cards-container" class="scroll-row"></div>
    </div>
</main>

<!-- Toast -->
<div class="toast" id="toast">
    <span id="toast-text"></span>
</div>

<%- include('partials/back-button') %>

<script>
(() => {
    const cardsContainer = document.getElementById('cards-container');
    const toast = document.getElementById('toast');
    const toastText = document.getElementById('toast-text');

    // ✅ Use myCollection from backend
    let destinations = <%- JSON.stringify(myCollection || []) %>;

    renderCards(destinations);

    function renderCards(list) {
        cardsContainer.innerHTML = '';

        if (!list || list.length === 0) {
            cardsContainer.parentElement.innerHTML = `
                <div class="empty-state">
                    <h2>Your Want-to-Go list is empty</h2>
                    <p>Start exploring destinations and add places you'd love to visit 🌍</p>
                    <button class="btn btn-success browse-btn" onclick="location.href='/home'">Browse Destinations</button>
                </div>`;
            return;
        }

        list.forEach((dest, index) => {
            const card = document.createElement('div');
            card.className = 'card';

            card.innerHTML = `
                <img src="/${dest.name}.png" alt="${dest.actualName}">
                <div class="card-body">
                    <div>
                        <h5 class="card-title">${dest.actualName}</h5>
                        <p><strong>Country:</strong> ${dest.country || 'Unknown'}</p>
                        <p><strong>Category:</strong> ${dest.actualCategoryName || 'General'}</p>
                        <p>${dest.description || ''}</p>
                    </div>
                    <div class="d-flex justify-content-center">
                        <button class="btn btn-primary mr-2" onclick="location.href='/destination/${dest.name}'">View Details</button>
                        <button class="btn btn-danger remove-btn" data-index="${index}" data-name="${dest.name}" data-actual-name="${dest.actualName}">Remove</button>
                    </div>
                </div>
            `;
            cardsContainer.appendChild(card);
        });

        bindRemoveButtons();
    }

    function bindRemoveButtons() {
        document.querySelectorAll('.remove-btn').forEach(btn => {
            btn.onclick = async () => {
                const index = btn.dataset.index;
                const name = btn.dataset.name;
                const actualName = btn.dataset.actualName;

                await fetch(`/destination/${name}/remove`, { method: 'POST' });

                destinations.splice(index, 1);
                renderCards(destinations);
                showToast(`Removed "${actualName}"`);
            };
        });
    }

    function showToast(msg) {
        toastText.innerText = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3000);
    }
})();
</script>

</body>
</html>
