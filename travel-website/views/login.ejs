<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login</title>
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
<style>
    body {
        background-image: url("/background1.jpg");
        background-size: cover;
        background-repeat: no-repeat;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden;
    }

    h1 {
    position: relative;
    transition: transform 0.3s ease, color 0.3s ease;
    font-weight: bold;
    color: #fff; /* default color */
    }

    .login-card {
        background-color: rgba(0, 0, 0, 0.8);
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.5);
        width: 100%;
        max-width: 400px;
        color: white;
        text-align: center;
        animation: fadeInCard 1s ease forwards;
        opacity: 0;
        transform: translateY(-30px);
    }

    @keyframes fadeInCard {
        to { opacity: 1; transform: translateY(0); }
    }

    .login-card img.logo {
        width: 100px;
        height: 100px;
        object-fit: contain;
        margin-bottom: 20px;
        animation: fadeInLogo 1s ease forwards;
        opacity: 0;
    }

    @keyframes fadeInLogo {
        to { opacity: 1; }
    }

    .login-card h2 {
        margin-bottom: 30px;
        -webkit-text-stroke: 1px black;
    }

    .form-control {
        border-radius: 8px;
    }

    .btn-primary {
        width: 100%;
        border-radius: 8px;
        background-color: #28a745;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        background-color: #218838;
    }

    .text-danger, .text-success {
        font-weight: bold;
        opacity: 0;
        transform: translateY(20px);
        animation-fill-mode: forwards;
        animation-duration: 0.6s;
    }

    .text-danger.animate {
        animation-name: slideInError;
    }

    .text-success.animate {
        animation-name: slideInSuccess;
    }

    @keyframes slideInError {
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes slideInSuccess {
        to { opacity: 1; transform: translateY(0); }
    }

    .register-link {
        display: block;
        margin-top: 20px;
        color: #17a2b8;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .register-link:hover {
        color: #138496;
        text-decoration: underline;
    }
</style>
</head>
<body>

<div class="login-card">
    <!-- Logo -->
    <img src="/traveltopia.png" alt="Traveltopia Logo" class="logo">

    <h1>Traveltopia</h1>
    <h2>Login</h2>
    <form method="POST" action="/login">
        <div class="form-group text-left">
            <label>Username</label>
            <input type="text" name="username" class="form-control" required>
        </div>
        <div class="form-group text-left">
            <label>Password</label>
            <input type="password" name="password" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary mt-3">Login</button>
    </form>

    <% if (error) { %>
        <p class="text-danger mt-3 animate"><%= error %></p>
    <% } %>
    <% if (success) { %>
        <p class="text-success mt-3 animate"><%= success %></p>
    <% } %>

    <a href="/register" class="register-link">I don't have an account</a>
</div>

</body>
</html>
