<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body {
            background-image: url("/background3.jpg");
            background-repeat: no-repeat;
            background-size: 100%;
        }
        h1 {
            color: white;
            text-align: center;
            -webkit-text-stroke: 1px blue;
        }
        .container1 {
            position: fixed;
            left: 50px;
            top: 150px;
            color: white;
        }
        .container2 {
            position: fixed;
            left: 300px;
            top: 150px;
            color: white;
            width: 300px;
            text-align: justify;
            text-justify: inter-word;
        }
        .video {
            position: fixed;
            left: 700px;
            top: 150px;
            color: white;
            width: 300px;
            text-align: justify;
            text-justify: inter-word;
        }
        .wanttogo {
            position: fixed;
            left: 30px;
            top: 470px;
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= destination.name %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <h1><%= destination.actualName %></h1>

<div class="wanttogo-btn-container">
    <form id="wantForm" method="POST" action="/destination/<%= destination.name %>/add">
        <button type="submit" class="btn btn-secondary">Add to Want-to-Go List</button>
    </form>

    <!-- Feedback Partial -->
    <%- include('partials/feedback-message', { message: error }) %>
</div>

<%- include('partials/back-button') %>

<script>
    const form = document.getElementById('wantForm');
    const feedback = document.getElementById('feedback-msg');

    form.addEventListener('submit', async (e) => {
        e.preventDefault(); // prevent default redirect
        const url = form.action;

        try {
            const res = await fetch(url, { method: 'POST' });
            const text = await res.text();

            let msg = 'Added to your Want-to-Go List!';
            if (text.includes('Already in your Want-to-Go')) {
                msg = 'Already in your Want-to-Go List!';
            }

            feedback.innerText = msg;
            feedback.classList.add('show');

            setTimeout(() => {
                feedback.classList.remove('show');
            }, 2500);

        } catch (err) {
            console.error(err);
            feedback.innerText = 'Error adding destination.';
            feedback.classList.add('show');
            setTimeout(() => feedback.classList.remove('show'), 2500);
        }
    });
</script>
    <div class="container1">
        <img id="image" src="/<%= destination.name %>.png" width="193" height="300" alt="<%= destination.name %>">
    </div>
    <div class="container2">
        <!-- You can add description text here if you want -->
        <p><strong>Category:</strong> <%= destination.category %></p>
    </div>
    <div class="wanttogo">
        <form method="POST" action="/destination/<%= destination.name %>/add">
            <button type="submit" class="btn btn-secondary ml-3">Add to Want-to-Go List</button>
        </form>
        <% if (error) { %>
            <p style="color:red;"><%= error %></p>
        <% } %>
    </div>
    <div class="video">
        <!-- Optional video placeholder -->
        <video width="480" height="360" controls>
            <source src="/<%= destination.name %>.mp4" type="video/mp4">
        </video>
    </div>
</body>
</html>
